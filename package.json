    "react-snap": "^1.23.0",
    "vite": "^7.1.2",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "publicPath": "/",
    "concurrency": 1,
    "include": [
      "/",
      "/404.html",
      "/about-aia",
      "/blogs",
      "/blogs/achieve-cfe-certification",
      "/blogs/anti-money-laundering-jobs-salary",
      "/blogs/benefits-of-becoming-cia",
      "/blogs/cams-exam-format",
      "/blogs/cams-exam-tips",
      "/blogs/cams-syllabus",
      "/blogs/certified-fraud-examiner",
      "/blogs/certified-fraud-examiner-salary",
      "/blogs/certified-internal-auditor-functions",
      "/blogs/cfe-certification-cost",
      "/blogs/cfe-exam-fees-and-retake-policy",
      "/blogs/cfe-exam-home-test-center",
      "/blogs/cfe-exam-success",
      "/blogs/cfe-fraud-skills",
      "/blogs/cfe-in-corporate-world",
      "/blogs/cfe-module-4",
      "/blogs/cia-certification",
      "/blogs/cia-certification-in-qatar",
      "/blogs/cia-exam-key-skills",
      "/blogs/cia-exam-preparation-tips",
      "/blogs/cia-exam-registration-process",
      "/blogs/cia-exam-syllabus",
      "/blogs/cia-part-1-syllabus",
      "/blogs/cia-part-2-syllabus",
      "/blogs/cia-part-3-syllabus",
      "/blogs/course/cams",
      "/blogs/course/cfe",
      "/blogs/course/cia",
      "/blogs/fraud-investigator",
      "/blogs/internal-audit",
      "/blogs/kyc-compliance",
      "/blogs/online-vs-offline-cfe-training",
      "/blogs/role-of-internal-audit-fraud",
      "/blogs/what-is-fraud",
      "/blogs/what-is-money-laundering",
      "/cams",
      "/cams-free-resources",
      "/cfe-curriculum",
      "/cfe-free-resources",
      "/cia-challenge-curriculum",
      "/cia-curriculum",
      "/cia-free-resources",
      "/contact",
      "/corporate-training"
    ],
    "crawl": false,
    "waitFor": 1000,
    "userAgent": "ReactSnap",
    "skipThirdPartyRequests": false,
    "cacheAjaxRequests": false,
    "preconnectThirdParty": false,
    "preloadImages": false,
    "inlineCss": false,
    "removeBlobs": true,
    "fixWebpackChunksIssue": false,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage",
      "--disable-gpu"
    ],
    "puppeteer": {
      "cache": false
    },
    "viewport": {
      "width": 1366,
      "height": 1200
    },
    "minifyHtml": {
      "collapseBooleanAttributes": true,
      "collapseWhitespace": true,
      "decodeEntities": true,
      "keepClosingSlash": true,
      "removeComments": false,
      "sortAttributes": true,
      "sortClassName": false
    },
    "port": 45679
  }
}
